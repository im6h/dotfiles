# yaml-language-server: $schema=https://taskfile.dev/schema.json

version: "3"

vars:
  CTN: '{{ .CTN | default "podman" }}'

tasks:
  ctn:common: &common
    dir: "{{.USER_WORKING_DIR}}"
    vars:
      NAME: '{{ .NAME | default "plog" }}'
      IMAGE: "ghcr.io/im6h/{{.NAME}}"
      HOST_DEST: root@10.2.0.1
      COMPOSE_DEST: '{{ .DEST | default "/root/docker-compose/npfhome/docker-compose.yaml" }}'

  ctn:build:
    desc: build
    <<: *common
    cmds:
      - "{{.CTN}} build -f Containerfile -t {{.IMAGE}} ."

  ctn:deployy:
    desc: deploy
    <<: *common
    cmds:
      - '{{.CTN | default "docker" }} pussh "{{.IMAGE}}" "{{.HOST_DEST}}"'
      - 'ssh {{.HOST_DEST}} "docker compose -f {{.COMPOSE_DEST}} up -d --force-recreate --no-deps"'
  ctn:prune:
    desc: prune system
    <<: *common
    cmds:
      - '{{.CTN }} image prune -a --filter "until=168h"'

  gh:pr:create:
    desc: create pr github
    dir: "{{.USER_WORKING_DIR}}"
    cmds:
      - gh pr create -f

  gh:pr:merge:
    desc: merge pr github
    dir: "{{.USER_WORKING_DIR}}"
    cmds:
      - gh pr merge -m -d

  sync: &sync
    vars:
      ODRIVE: "od://Apps/remotely-save/second_brain/"
      GDRIVE: "gd://Apps/remotely-save/second_brain/"
      LOCAL: "/home/doku/Documents/second_brain/"

  sync:od:down:
    desc: sync cloud to local
    <<: *sync
    cmds:
      - "rclone copy {{.ODRIVE}} {{.LOCAL}} -v && qmd update"

  sync:od:up:
    desc: sync local to cloud
    <<: *sync
    cmds:
      - "rclone copy {{.LOCAL}} {{.ODRIVE}} -v"

  sync:gd:up:
    desc: sync local to cloud
    <<: *sync
    cmds:
      - "rclone copy {{.LOCAL}} {{.GDRIVE}} -v"

  harness:init:
    dir: "{{.USER_WORKING_DIR}}"
    vars:
      OCI: quay.io/ncdv/d3-tools:harness-0.0.1
    cmds:
      - "{{.CTN}} run --rm -v ./:/usr/src/app {{.OCI}}"

  pkg:bk:
    dir: /home/doku/onedrive/backup/dotfiles/
    vars:
      DST: /home/doku/onedrive/backup/dotfiles/
      HOME: /home/doku/
      AUR: "pacman-aur"
      NATIVE: "pacman-native"
    cmds:
      - "pacman -Qqen > {{.DST}}{{.AUR}}.txt"
      - "pacman -Qqem > {{.DST}}{{.NATIVE}}.txt"
      - "cp {{.HOME}}/Taskfile.yml {.{DST}}"
      - 'git add . && git commit -m "backup arch pkgs"'
      - "git push origin main"
